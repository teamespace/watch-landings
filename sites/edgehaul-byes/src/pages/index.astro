---
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EDGEHAUL — Tactical Carry Systems</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link is:inline rel="stylesheet" href="/styles.css">
</head>
<body>

<div class="topbar">
  <div class="topbar-inner">
    <span>FREE SHIPPING ON ALL ORDERS OVER $150</span>
    <span>SUBSCRIBE FOR 10% OFF FIRST PURCHASE</span>
    <span>30-DAY RETURN POLICY</span>
  </div>
</div>

<header class="header">
  <div class="header-inner">
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
    <nav class="nav-left">
      <a href="#">NEW ARRIVALS</a>
      <a href="#">SHOP</a>
      <a href="#">SERIES</a>
      <a href="#">GEAR</a>
    </nav>
    <div class="logo">
      <span class="logo-text">EDGEHAUL</span>
    </div>
    <div class="header-right">
      <nav class="nav-right">
        <a href="#">EXPLORE</a>
        <a href="#">STORIES</a>
        <a href="#">SALE</a>
      </nav>
      <div class="header-actions">
        <button class="icon-btn" aria-label="Search">⌕</button>
        <button class="icon-btn" aria-label="Cart">◷</button>
      </div>
    </div>
  </div>
</header>

<nav class="mobile-nav" id="mobileNav">
  <div class="mobile-nav-inner">
    <a href="#">NEW ARRIVALS</a>
    <a href="#">BACKPACKS</a>
    <a href="#">SLING BAGS</a>
    <a href="#">MESSENGERS</a>
    <a href="#">ACCESSORIES</a>
    <a href="#">SERIES</a>
    <a href="#">SALE</a>
    <a href="#">EXPLORE</a>
  </div>
</nav>

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="hero-label">URBAN EXPLORATION GEAR</p>
    <h1 class="hero-title">Built for the<br><span class="text-accent">Concrete Wild</span></h1>
    <p class="hero-desc">Modular carry systems engineered for the modern adventurer. Military-grade materials, urban-ready design.</p>
    <div class="hero-btns">
      <a href="#" class="btn btn-primary">SHOP COLLECTION</a>
      <a href="#" class="btn btn-outline">EXPLORE SERIES</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">NEW ARRIVALS</span>
      <h2 class="section-title">Latest Drops</h2>
      <a href="#" class="section-link">View All →</a>
    </div>
    <div class="product-grid" id="productGrid">
    </div>
  </div>
</section>

<section class="section section-dark">
  <div class="container">
    <div class="featured">
      <div class="featured-image">
        <div class="featured-image-frame">
          <img src="/assets/featured/nighthawk.png" alt="R101 Nighthawk" loading="eager">
        </div>
      </div>
      <div class="featured-content">
        <span class="product-series">ADV SYSTEM MK25</span>
        <h2 class="featured-title">R101 "Nighthawk"</h2>
        <p class="featured-desc">The pinnacle of modular backpack design. featuring our proprietary Quick-Draw harness system, 1680D ballistic nylon construction, and a fully configurable interior organization matrix.</p>
        <div class="featured-specs">
          <div class="spec">
            <span class="spec-value">28L</span>
            <span class="spec-label">Capacity</span>
          </div>
          <div class="spec">
            <span class="spec-value">1.8kg</span>
            <span class="spec-label">Weight</span>
          </div>
          <div class="spec">
            <span class="spec-value">1680D</span>
            <span class="spec-label">Material</span>
          </div>
          <div class="spec">
            <span class="spec-value">IPX4</span>
            <span class="spec-label">Rating</span>
          </div>
        </div>
        <div class="featured-price">$299.00</div>
        <div class="featured-actions">
          <a href="#" class="btn btn-primary">VIEW DETAILS</a>
          <a href="#" class="btn btn-outline">QUICK ADD</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">COLLECTIONS</span>
      <h2 class="section-title">Explore Series</h2>
    </div>
    <div class="series-grid">
      <a href="#" class="series-card">
        <div class="series-card-bg" style="background-image: url('/assets/series/adv.png')"></div>
        <div class="series-card-content">
          <h3>ADV System</h3>
          <p>Tactical modular system</p>
        </div>
      </a>
      <a href="#" class="series-card">
        <div class="series-card-bg" style="background-image: url('/assets/series/core.png')"></div>
        <div class="series-card-content">
          <h3>CORE Series</h3>
          <p>Everyday essential</p>
        </div>
      </a>
      <a href="#" class="series-card">
        <div class="series-card-bg" style="background-image: url('/assets/series/sling.png')"></div>
        <div class="series-card-content">
          <h3>SLING System</h3>
          <p>Minimalist carry</p>
        </div>
      </a>
      <a href="#" class="series-card">
        <div class="series-card-bg" style="background-image: url('/assets/series/mod.png')"></div>
        <div class="series-card-content">
          <h3>MOD System</h3>
          <p>Modular add-ons</p>
        </div>
      </a>
    </div>
  </div>
</section>

<section class="section section-recon">
  <div class="container">
    <div class="recon">
      <div class="recon-content">
        <span class="section-label">FIELD TESTED</span>
        <h2>Built for the Mission</h2>
        <p>Every component is tested in real urban environments. From the monsoon season in Southeast Asia to the streets of Tokyo — our gear is built to perform when it matters.</p>
        <ul class="recon-list">
          <li>✕ 1680D Ballistic Nylon</li>
          <li>✕ YKK AquaGuard Zippers</li>
          <li>✕ Duraflex Hardware</li>
          <li>✕ 5-Year Warranty</li>
        </ul>
        <a href="#" class="btn btn-primary">OUR STORY</a>
      </div>
      <div class="recon-image">
        <div class="recon-image-frame">
          <img src="/assets/recon.png" alt="Field tested in urban environments" loading="lazy">
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">FOLLOW US</span>
      <h2 class="section-title">@edgehaul_gear</h2>
    </div>
    <div class="social-grid">
      <div class="social-card"><img src="/assets/social/01.png" alt="EDGEHAUL in the field" loading="lazy"></div>
      <div class="social-card"><img src="/assets/social/02.png" alt="Hardware detail" loading="lazy"></div>
      <div class="social-card"><img src="/assets/social/03.png" alt="Urban carry" loading="lazy"></div>
      <div class="social-card"><img src="/assets/social/04.png" alt="Organized interior" loading="lazy"></div>
      <div class="social-card"><img src="/assets/social/05.png" alt="Street ready" loading="lazy"></div>
      <div class="social-card"><img src="/assets/social/06.png" alt="MOLLE system" loading="lazy"></div>
    </div>
  </div>
</section>

<section class="newsletter">
  <div class="container">
    <h2>Stay in the Loop</h2>
    <p>Get early access to drops, field test reports, and exclusive patches.</p>
    <form class="newsletter-form">
      <input type="email" placeholder="Enter your email" required>
      <button type="submit" class="btn btn-primary">SUBSCRIBE</button>
    </form>
  </div>
</section>

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="logo">
          <span class="logo-text">EDGEHAUL</span>
        </div>
        <p>Tactical carry systems for urban exploration.</p>
        <div class="social-links">
          <a href="#" aria-label="Instagram">📷</a>
          <a href="#" aria-label="YouTube">▶</a>
          <a href="#" aria-label="X">✕</a>
        </div>
      </div>
      <div class="footer-col">
        <h4>SHOP</h4>
        <a href="#">Backpacks</a>
        <a href="#">Sling Bags</a>
        <a href="#">Messengers</a>
        <a href="#">Accessories</a>
        <a href="#">Sale</a>
      </div>
      <div class="footer-col">
        <h4>EXPLORE</h4>
        <a href="#">Our Story</a>
        <a href="#">Field Tests</a>
        <a href="#">Technology</a>
        <a href="#">Retailers</a>
      </div>
      <div class="footer-col">
        <h4>SUPPORT</h4>
        <a href="#">Warranty</a>
        <a href="#">Shipping</a>
        <a href="#">Returns</a>
        <a href="#">Size Guide</a>
        <a href="#">Contact</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2026 EDGEHAUL. All rights reserved.</p>
    </div>
  </div>
</footer>

<script is:inline src="/script.js"></script>
</body>
</html>
