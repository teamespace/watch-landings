---
import { StrapBuilderCarousel } from '../components/StrapBuilderCarousel.tsx'
---

<section class="py-16 px-6 max-w-5xl mx-auto text-center">
  <h2 class="text-3xl font-bold lowercase mb-2">Same watch. Different mood.</h2>
  <p class="text-sm text-[#888888] mb-8">Swap your strap in seconds. No tools needed.</p>
  <StrapBuilderCarousel client:visible />
  <div class="mt-6">
    <a href="/straps" class="inline-block border border-[#111] text-[#111] px-8 py-3 text-sm font-medium lowercase hover:bg-[#111] hover:text-white transition-colors">
      Browse straps
    </a>
  </div>
</section>
