---
import { StrapBuilderCarousel } from '../components/StrapBuilderCarousel.tsx'
---

<section class="py-20 md:py-28 px-6 max-w-5xl mx-auto text-center">
  <h2 class="text-4xl md:text-5xl font-bold lowercase tracking-tight mb-3">Same watch. Different mood.</h2>
  <p class="text-base text-brand-text-secondary mb-10">Swap your strap in seconds. No tools needed.</p>
  <StrapBuilderCarousel client:visible />
  <div class="mt-8">
    <a href="/straps" class="btn-secondary">
      Browse straps
    </a>
  </div>
</section>
