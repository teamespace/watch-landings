---
import { AnimatedNumber } from 'skiper-islands'
---

<section class="bg-brand-surface py-5">
  <div class="max-w-6xl mx-auto flex flex-wrap justify-center items-center gap-8 md:gap-20 px-6">
    <div class="flex items-center gap-2.5 text-sm font-medium text-brand-primary">
      <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="#2D4A3E" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
      <span>Designed in Stockholm</span>
    </div>
    <div class="flex items-center gap-2.5 text-sm font-medium text-brand-primary">
      <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="#2D4A3E" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      <span>2-year warranty</span>
    </div>
    <div class="flex items-center gap-2.5 text-sm font-medium text-brand-primary">
      <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="#2D4A3E" stroke-width="1.5"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
      <span>Free returns</span>
    </div>
    <div class="flex items-center gap-1.5 text-sm font-medium text-brand-primary">
      <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="#2D4A3E" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      <AnimatedNumber to={1500000} suffix="+" fontSize="14px" color="#111" fontWeight={500} />
      <span>sold</span>
    </div>
  </div>
</section>
