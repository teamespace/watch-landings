---

<section class="py-20 md:py-28 px-6 bg-white">
  <div class="max-w-lg mx-auto text-center">
    <h2 class="text-4xl md:text-5xl font-bold lowercase tracking-tight mb-4">Get first dibs.</h2>
    <p class="text-base text-brand-text-secondary mb-10 leading-relaxed">
      New drops, behind-the-scenes stuff, and offers that don't go on the main site.
    </p>
    <form class="flex flex-col sm:flex-row gap-3" onsubmit="this.querySelector('input').value = ''; alert('Thanks!')">
      <input
        type="email"
        placeholder="Your email"
        required
        class="flex-1 border border-black/10 px-4 py-3.5 text-sm outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-all"
      />
      <button
        type="submit"
        class="btn-primary whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>
    <p class="text-[11px] text-brand-text-secondary mt-4 tracking-wide">(No spam. Unsubscribe anytime.)</p>
  </div>
</section>
