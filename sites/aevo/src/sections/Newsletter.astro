---
---

<section class="py-20 px-6 bg-white">
  <div class="max-w-lg mx-auto text-center">
    <h2 class="text-3xl font-bold lowercase mb-3">Get first dibs.</h2>
    <p class="text-sm text-[#888888] mb-8 leading-relaxed">
      New drops, behind-the-scenes stuff, and offers that don't go on the main site.
    </p>
    <form class="flex flex-col sm:flex-row gap-3" onsubmit="this.querySelector('input').value = ''; alert('Thanks!')">
      <input
        type="email"
        placeholder="Your email"
        required
        class="flex-1 border border-gray-200 px-4 py-3 text-sm outline-none focus:border-[#2D4A3E] transition-colors"
      />
      <button
        type="submit"
        class="bg-[#2D4A3E] text-white px-8 py-3 text-sm font-medium lowercase hover:bg-[#1D3A2E] transition-colors whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>
    <p class="text-[11px] text-[#888888] mt-4">(No spam. Unsubscribe anytime.)</p>
  </div>
</section>
