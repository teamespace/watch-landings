---

<footer class="bg-[#111111] text-white py-14 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-4 gap-10 mb-12">
      <div>
        <h4 class="text-sm font-bold uppercase tracking-wider text-[#888888] mb-4">Watches</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/watches" class="hover:text-white transition-colors">All watches</a></li>
          <li><a href="/collections/daylight" class="hover:text-white transition-colors">Daylight</a></li>
          <li><a href="/collections/traveler" class="hover:text-white transition-colors">Traveler</a></li>
          <li><a href="/collections/coastal" class="hover:text-white transition-colors">Coastal</a></li>
          <li><a href="/collections/summer" class="hover:text-white transition-colors">Summer 2026</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-bold uppercase tracking-wider text-[#888888] mb-4">Straps</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/straps" class="hover:text-white transition-colors">All straps</a></li>
          <li><a href="/straps/leather" class="hover:text-white transition-colors">Leather</a></li>
          <li><a href="/straps/nato" class="hover:text-white transition-colors">NATO</a></li>
          <li><a href="/straps/mesh" class="hover:text-white transition-colors">Mesh</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-bold uppercase tracking-wider text-[#888888] mb-4">About</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/about" class="hover:text-white transition-colors">Our story</a></li>
          <li><a href="/collabs" class="hover:text-white transition-colors">Collabs</a></li>
          <li><a href="/sustainability" class="hover:text-white transition-colors">Sustainability</a></li>
          <li><a href="/journal" class="hover:text-white transition-colors">Journal</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-bold uppercase tracking-wider text-[#888888] mb-4">Help</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/shipping" class="hover:text-white transition-colors">Shipping</a></li>
          <li><a href="/returns" class="hover:text-white transition-colors">Returns</a></li>
          <li><a href="/warranty" class="hover:text-white transition-colors">Warranty</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-4">
        <a href="https://instagram.com" aria-label="Instagram" class="text-white/60 hover:text-white transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://tiktok.com" aria-label="TikTok" class="text-white/60 hover:text-white transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
        </a>
        <a href="https://youtube.com" aria-label="YouTube" class="text-white/60 hover:text-white transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/><rect x="2" y="3" width="20" height="18" rx="3"/></svg>
        </a>
      </div>
      <div class="flex items-center gap-3 text-xs text-white/40">
        <span>Visa</span>
        <span>MC</span>
        <span>PayPal</span>
        <span>Apple Pay</span>
      </div>
      <div class="text-xs text-white/40 text-center">
        Designed in Stockholm &copy; {new Date().getFullYear()} Aevo
      </div>
    </div>
  </div>
</footer>
