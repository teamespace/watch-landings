---
---

<footer class="bg-brand-primary text-white py-16 md:py-20 px-6">
  <div class="max-w-7xl mx-auto">
    <a href="/" class="inline-block text-brand-accent text-2xl font-bold lowercase tracking-tight mb-10">
      aevo
    </a>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 mb-14">
      <div>
        <h4 class="text-[11px] font-bold uppercase tracking-[0.2em] text-white/40 mb-5">Watches</h4>
        <ul class="space-y-3 text-sm text-white/60">
          <li><a href="/watches" class="hover:text-white transition-colors duration-200">All watches</a></li>
          <li><a href="/collections/daylight" class="hover:text-white transition-colors duration-200">Daylight</a></li>
          <li><a href="/collections/traveler" class="hover:text-white transition-colors duration-200">Traveler</a></li>
          <li><a href="/collections/coastal" class="hover:text-white transition-colors duration-200">Coastal</a></li>
          <li><a href="/collections/summer" class="hover:text-white transition-colors duration-200">Summer 2026</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-[11px] font-bold uppercase tracking-[0.2em] text-white/40 mb-5">Straps</h4>
        <ul class="space-y-3 text-sm text-white/60">
          <li><a href="/straps" class="hover:text-white transition-colors duration-200">All straps</a></li>
          <li><a href="/straps/leather" class="hover:text-white transition-colors duration-200">Leather</a></li>
          <li><a href="/straps/nato" class="hover:text-white transition-colors duration-200">NATO</a></li>
          <li><a href="/straps/mesh" class="hover:text-white transition-colors duration-200">Mesh</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-[11px] font-bold uppercase tracking-[0.2em] text-white/40 mb-5">About</h4>
        <ul class="space-y-3 text-sm text-white/60">
          <li><a href="/about" class="hover:text-white transition-colors duration-200">Our story</a></li>
          <li><a href="/collabs" class="hover:text-white transition-colors duration-200">Collabs</a></li>
          <li><a href="/sustainability" class="hover:text-white transition-colors duration-200">Sustainability</a></li>
          <li><a href="/journal" class="hover:text-white transition-colors duration-200">Journal</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-[11px] font-bold uppercase tracking-[0.2em] text-white/40 mb-5">Help</h4>
        <ul class="space-y-3 text-sm text-white/60">
          <li><a href="/shipping" class="hover:text-white transition-colors duration-200">Shipping</a></li>
          <li><a href="/returns" class="hover:text-white transition-colors duration-200">Returns</a></li>
          <li><a href="/warranty" class="hover:text-white transition-colors duration-200">Warranty</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors duration-200">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-5">
        <a href="https://instagram.com" aria-label="Instagram" class="text-white/50 hover:text-white transition-colors duration-200">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://tiktok.com" aria-label="TikTok" class="text-white/50 hover:text-white transition-colors duration-200">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
        </a>
        <a href="https://youtube.com" aria-label="YouTube" class="text-white/50 hover:text-white transition-colors duration-200">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/><rect x="2" y="3" width="20" height="18" rx="3"/></svg>
        </a>
      </div>
      <div class="flex items-center gap-4 text-[11px] font-medium uppercase tracking-[0.15em] text-white/40">
        <span>Visa</span>
        <span>Mastercard</span>
        <span>PayPal</span>
        <span>Apple Pay</span>
      </div>
      <div class="text-xs text-white/40 text-center md:text-right">
        Designed in Stockholm &copy; {new Date().getFullYear()} Aevo
      </div>
    </div>
  </div>
</footer>
