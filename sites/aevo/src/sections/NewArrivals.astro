---
import products from '../data/products.json'
import { NewArrivalsGrid } from '../components/NewArrivalsGrid.tsx'

const newProducts = products.filter(p => p.new)
---

<section class="py-20 md:py-28 px-6 max-w-7xl mx-auto">
  <h2 class="text-4xl md:text-5xl font-bold lowercase tracking-tight mb-12">Just dropped</h2>
  <NewArrivalsGrid products={newProducts} client:visible />
  <div class="mt-14 text-center">
    <a href="/watches" class="btn-secondary">
      See all new watches
    </a>
  </div>
</section>
