---
import products from '../data/products.json'
import { BestsellersCarousel } from '../components/BestsellersCarousel.tsx'

const bestsellers = products.slice(0, 4)
---

<section class="py-16 px-6 max-w-6xl mx-auto">
  <h2 class="text-3xl font-bold lowercase mb-8">The ones everyone keeps buying.</h2>
  <BestsellersCarousel products={bestsellers} client:visible />
  <div class="mt-10 text-center">
    <a href="/watches" class="inline-block border border-[#111] text-[#111] px-8 py-3 text-sm font-medium lowercase hover:bg-[#111] hover:text-white transition-colors">
      All bestsellers
    </a>
  </div>
</section>
