---
import products from '../data/products.json'
import { BestsellersCarousel } from '../components/BestsellersCarousel.tsx'

const bestsellers = products.slice(0, 4)
---

<section class="py-20 md:py-28 px-6 max-w-7xl mx-auto">
  <h2 class="text-4xl md:text-5xl font-bold lowercase tracking-tight mb-12">The ones everyone keeps buying.</h2>
  <BestsellersCarousel products={bestsellers} client:visible />
  <div class="mt-14 text-center">
    <a href="/watches" class="btn-secondary">
      All bestsellers
    </a>
  </div>
</section>
