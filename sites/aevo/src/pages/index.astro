---
import BaseLayout from '../layouts/BaseLayout.astro'
import AnnouncementBar from '../sections/AnnouncementBar.astro'
import Nav from '../sections/Nav.astro'
import Hero from '../sections/Hero.astro'
import FeatureShowcase from '../components/FeatureShowcase.tsx'
import TrustBar from '../sections/TrustBar.astro'
import NewArrivals from '../sections/NewArrivals.astro'
import CollabBlock from '../sections/CollabBlock.astro'
import Bestsellers from '../sections/Bestsellers.astro'
import PressStrip from '../sections/PressStrip.astro'
import Reviews from '../sections/Reviews.astro'
import AboutTeaser from '../sections/AboutTeaser.astro'
import StrapBuilder from '../sections/StrapBuilder.astro'
import Newsletter from '../sections/Newsletter.astro'
import Footer from '../sections/Footer.astro'
---

<BaseLayout title="Aevo — Designed for a life in motion" themeColor="#FFFFFF">
  <AnnouncementBar />
  <Nav />
  <Hero />
  <FeatureShowcase client:load />
  <TrustBar />
  <NewArrivals />
  <CollabBlock />
  <Bestsellers />
  <PressStrip />
  <Reviews />
  <AboutTeaser />
  <StrapBuilder />
  <Newsletter />
  <Footer />
</BaseLayout>
