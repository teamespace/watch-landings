---
const families = [
  {
    id: 'linie',
    name: 'Linie',
    description: 'Dress, thin case',
    count: '2 models',
    image: 'https://picsum.photos/seed/watch+product+front+white/400/400',
  },
  {
    id: 'punkt',
    name: 'Punkt',
    description: 'Minimalist field',
    count: '2 models',
    image: 'https://picsum.photos/seed/watch+product+front+white/400/400',
  },
  {
    id: 'raster',
    name: 'Raster',
    description: 'Grid-dial sport',
    count: '2 models',
    image: 'https://picsum.photos/seed/watch+product+front+white/400/400',
  },
  {
    id: 'fuge',
    name: 'Fuge',
    description: 'Dress GMT',
    count: '1 model',
    image: 'https://picsum.photos/seed/watch+product+front+white/400/400',
  },
  {
    id: 'block',
    name: 'Block',
    description: 'Bold case, technical',
    count: '1 model',
    image: 'https://picsum.photos/seed/watch+product+front+white/400/400',
  },
]
---

<section class="bg-white py-20 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-[#0A0A0A] mb-3">
      Five families. One design language.
    </h2>
    <p class="text-[#666666] text-sm max-w-xl mb-12">
      Each Formd family starts from a single formal question. They are not variations — they are distinct answers.
    </p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-[#E0E0E0]">
      {families.map((f) => (
        <a href={`/watches/families/${f.id}`} class="group block bg-white hover:bg-[#F5F5F5] transition-colors p-4">
          <img src={f.image} alt={f.name} class="w-full h-48 object-contain" />
          <div class="mt-4">
            <h3 class="text-sm font-bold text-[#0A0A0A] uppercase tracking-widest">{f.name}</h3>
            <p class="text-xs text-[#666666] uppercase tracking-widest mt-1 opacity-0 group-hover:opacity-100 transition-opacity">{f.description}</p>
            <p class="text-xs text-[#666666] mt-1 opacity-0 group-hover:opacity-100 transition-opacity">{f.count}</p>
            <span class="inline-block text-xs text-[#CC2200] mt-2 uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity">Explore</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
