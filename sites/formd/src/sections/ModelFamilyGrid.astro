---
const families = [
  {
    id: 'linie',
    name: 'Linie',
    description: 'Dress, thin case',
    count: '2 models',
    image: 'https://picsum.photos/seed/watch+product+front+white/400/400',
  },
  {
    id: 'punkt',
    name: 'Punkt',
    description: 'Minimalist field',
    count: '2 models',
    image: 'https://picsum.photos/seed/watch+product+front+white/400/400',
  },
  {
    id: 'raster',
    name: 'Raster',
    description: 'Grid-dial sport',
    count: '2 models',
    image: 'https://picsum.photos/seed/watch+product+front+white/400/400',
  },
  {
    id: 'fuge',
    name: 'Fuge',
    description: 'Dress GMT',
    count: '1 model',
    image: 'https://picsum.photos/seed/watch+product+front+white/400/400',
  },
  {
    id: 'block',
    name: 'Block',
    description: 'Bold case, technical',
    count: '1 model',
    image: 'https://picsum.photos/seed/watch+product+front+white/400/400',
  },
]
---

<section class="bg-white py-20 md:py-28 px-6 md:px-10 lg:px-16">
  <div class="max-w-[1440px] mx-auto">
    <div class="max-w-3xl mb-16 md:mb-20">
      <h2 class="text-display-lg font-bold text-brand-primary mb-5">
        Five families. One design language.
      </h2>
      <p class="text-body text-brand-text-secondary max-w-xl">
        Each Formd family starts from a single formal question. They are not variations — they are distinct answers.
      </p>
    </div>

    <div class="border-t border-l border-brand-grid">
      <div class="grid grid-cols-2 md:grid-cols-4">
        {families.map((f) => (
          <a
            href={`/watches/families/${f.id}`}
            class="group block border-r border-b border-brand-grid bg-white hover:bg-brand-surface transition-colors duration-300"
          >
            <div class="aspect-[4/3] flex items-center justify-center p-6 md:p-8">
              <img
                src={f.image}
                alt={f.name}
                class="w-full h-full object-contain transition-transform duration-500 ease-formd group-hover:scale-[1.03]"
              />
            </div>
            <div class="px-5 pb-6 pt-2 md:px-7 md:pb-7">
              <div class="flex items-baseline justify-between gap-3">
                <h3 class="text-label font-bold text-brand-primary">{f.name}</h3>
                <span class="text-label text-brand-text-secondary tabular-nums">{f.count}</span>
              </div>
              <p class="text-label text-brand-text-secondary mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 translate-y-1 group-hover:translate-y-0">
                {f.description}
              </p>
              <span class="block text-label text-brand-accent mt-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300 translate-y-1 group-hover:translate-y-0">
                Explore
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
