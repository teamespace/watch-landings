---
import { TextRevealBox } from 'skiper-islands'
import products from '../data/products.json'

const newProducts = products.filter((p) => p.new).slice(0, 3)
---

<section class="bg-white py-16 px-6 md:px-12 border-t border-[#E0E0E0]">
  <div class="max-w-7xl mx-auto">
    <TextRevealBox
      text="Just released"
      as="h2"
      fontSize="clamp(1.25rem, 2vw, 1.75rem)"
      fontWeight={700}
      color="#0A0A0A"
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-10">
      {newProducts.map((p) => (
        <a href={`/watches/${p.id}`} class="group block">
          <div class="bg-white aspect-square flex items-center justify-center border border-[#E0E0E0]">
            <img
              src={`https://source.unsplash.com/400x400/?watch+bauhaus+minimal&sig=${p.id}`}
              alt={p.name}
              class="w-3/4 h-3/4 object-contain"
            />
          </div>
          <div class="mt-4 flex items-center justify-between">
            <div>
              <h3 class="text-sm font-bold text-[#0A0A0A] uppercase tracking-widest">{p.name}</h3>
              <p class="text-xs text-[#666666] mt-1">{p.family}</p>
            </div>
            <span class="text-xs bg-[#CC2200] text-white px-2 py-0.5 uppercase tracking-wider">New</span>
          </div>
          <p class="text-sm text-[#0A0A0A] mt-1">{p.price}</p>
        </a>
      ))}
    </div>
  </div>
</section>
