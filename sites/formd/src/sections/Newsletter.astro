---
---

<section class="bg-white py-20 md:py-28 px-6 md:px-10 lg:px-16 border-t border-brand-grid">
  <div class="max-w-[1440px] mx-auto grid md:grid-cols-12 gap-12 md:gap-16">
    <div class="md:col-span-5">
      <h2 class="text-display-md font-bold text-brand-primary mb-4">
        Our newsletter. One email per release.
      </h2>
      <p class="text-body text-brand-text-secondary leading-relaxed">
        No monthly updates. No lifestyle content. Just a note when something new is ready.
      </p>
    </div>

    <div class="md:col-span-7 flex flex-col justify-center">
      <form class="flex flex-col gap-4" onsubmit="return false">
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            type="email"
            placeholder="Your email address"
            class="flex-1 border border-brand-grid px-4 py-3.5 text-body text-brand-primary bg-white outline-none focus:border-brand-accent transition-colors duration-200"
          />
          <select class="border border-brand-grid px-4 py-3.5 text-label text-brand-text-secondary bg-white uppercase tracking-wider outline-none focus:border-brand-accent transition-colors duration-200">
            <option>English</option>
            <option>German</option>
          </select>
          <button
            type="submit"
            class="bg-brand-primary text-white text-label px-8 py-3.5 uppercase tracking-wider hover:bg-brand-primary/90 transition-colors duration-300"
          >
            Subscribe
          </button>
        </div>
        <label class="flex items-start gap-3 text-body-sm text-brand-text-secondary mt-2">
          <input type="checkbox" class="accent-brand-accent mt-0.5" />
          <span>I agree to the privacy policy</span>
        </label>
      </form>
    </div>
  </div>
</section>
