---
---

<section class="bg-white py-20 px-6 md:px-12 border-t border-[#E0E0E0]">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-[#0A0A0A] mb-3">
      Our newsletter. One email per release.
    </h2>
    <p class="text-sm text-[#666666] mb-8">
      No monthly updates. No lifestyle content. Just a note when something new is ready.
    </p>
    <form class="flex flex-col gap-4 max-w-md mx-auto" onsubmit="return false">
      <input
        type="email"
        placeholder="Your email address"
        class="w-full border border-[#E0E0E0] px-4 py-3 text-sm text-[#0A0A0A] bg-white outline-none focus:border-[#CC2200] transition-colors"
      />
      <div class="flex gap-4 items-center justify-center">
        <select class="border border-[#E0E0E0] px-3 py-3 text-xs text-[#666666] bg-white uppercase tracking-wider">
          <option>English</option>
          <option>German</option>
        </select>
        <button
          type="submit"
          class="bg-[#0A0A0A] text-white text-sm px-8 py-3 uppercase tracking-wider hover:opacity-90 transition-opacity"
        >
          Subscribe
        </button>
      </div>
      <label class="flex items-center gap-2 text-xs text-[#666666] justify-center">
        <input type="checkbox" class="accent-[#CC2200]" />
        I agree to the privacy policy
      </label>
    </form>
  </div>
</section>
