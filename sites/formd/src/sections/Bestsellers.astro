---
import products from '../data/products.json'

const topProducts = products.filter((p) => !p.new).slice(0, 4)
---

<section class="bg-white py-20 md:py-28 px-6 md:px-10 lg:px-16">
  <div class="max-w-[1440px] mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-12 md:mb-16">
      <h2 class="text-display-lg font-bold text-brand-primary">
        The ones people keep coming back to
      </h2>
      <a
        href="/watches"
        class="inline-block border border-brand-primary text-brand-primary text-label px-7 py-3 hover:bg-brand-primary hover:text-white transition-colors duration-300 self-start md:self-auto"
      >
        Shop bestsellers
      </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-brand-grid">
      {topProducts.map((p) => (
        <a href={`/watches/${p.id}`} class="group block bg-white hover:bg-brand-surface transition-colors duration-300">
          <div class="aspect-square flex items-center justify-center p-6 md:p-8">
            <img
              src={`https://picsum.photos/seed/watch+product+front+clean+${p.id}/400/400`}
              alt={p.name}
              class="w-full h-full object-contain transition-transform duration-500 ease-formd group-hover:scale-[1.03]"
            />
          </div>
          <div class="px-5 pb-6 pt-2 md:px-6 md:pb-7 border-t border-brand-grid">
            <h3 class="text-label font-bold text-brand-primary">{p.name}</h3>
            <p class="text-body-sm text-brand-text-secondary mt-1.5">{p.family}</p>
            <p class="text-body-sm text-brand-primary mt-2 tabular-nums">{p.price}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
