---
import products from '../data/products.json'

const topProducts = products.filter((p) => !p.new).slice(0, 4)
---

<section class="bg-white py-20 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-[#0A0A0A] mb-12">
      The ones people keep coming back to
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {topProducts.map((p) => (
        <a href={`/watches/${p.id}`} class="group block">
          <div class="bg-white border border-[#E0E0E0] aspect-square flex items-center justify-center">
            <img
              src={`https://source.unsplash.com/400x400/?watch+product+front+clean&sig=${p.id}`}
              alt={p.name}
              class="w-3/4 h-3/4 object-contain"
            />
          </div>
          <h3 class="text-sm font-bold text-[#0A0A0A] uppercase tracking-widest mt-4">{p.name}</h3>
          <p class="text-sm text-[#666666] mt-1">{p.price}</p>
        </a>
      ))}
    </div>
    <div class="text-center mt-12">
      <a
        href="/watches"
        class="inline-block border border-[#0A0A0A] text-[#0A0A0A] text-sm px-8 py-3 uppercase tracking-wider hover:bg-[#0A0A0A] hover:text-white transition-colors"
      >
        Shop bestsellers
      </a>
    </div>
  </div>
</section>
