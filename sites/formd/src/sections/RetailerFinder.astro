<section class="bg-brand-surface py-20 md:py-28 px-6 md:px-10 lg:px-16">
  <div class="max-w-[1440px] mx-auto">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
      <div>
        <h2 class="text-display-lg font-bold text-brand-primary mb-5">
          Find a Formd retailer near you.
        </h2>
        <p class="text-body text-brand-text-secondary max-w-md leading-relaxed">
          We work with a small network of selected partners worldwide. Each one shares our commitment to precision and service.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 md:justify-end">
        <a
          href="/retailers"
          class="inline-block bg-brand-primary text-white text-label px-8 py-3.5 text-center hover:bg-brand-primary/90 transition-colors duration-300"
        >
          Find a retailer
        </a>
        <a
          href="/shop"
          class="inline-block border border-brand-primary text-brand-primary text-label px-8 py-3.5 text-center hover:bg-brand-primary hover:text-white transition-colors duration-300"
        >
          Visit our online shop
        </a>
      </div>
    </div>
  </div>
</section>
