---
const teasers = [
  {
    title: 'Watchmaking tradition',
    text: 'Rooted in classical horology, our methods honor the craft while embracing precision engineering.',
    image: 'https://picsum.photos/seed/watchmaker+hands+bench+detail/600/400',
    link: '/watchmaking/tradition',
  },
  {
    title: 'Research + Development',
    text: 'Our in-house R&D team pushes the boundaries of movement architecture and material science.',
    image: 'https://picsum.photos/seed/watch+movement+caliber+macro/600/400',
    link: '/watchmaking/rd',
  },
  {
    title: 'In-house calibers',
    text: 'Every caliber is designed, assembled, and regulated in our workshops. No third-party movements.',
    image: 'https://picsum.photos/seed/gears+machinery+precision/600/400',
    link: '/watchmaking/calibers',
  },
]
---

<section class="bg-white py-20 md:py-28 px-6 md:px-10 lg:px-16 border-b border-brand-grid">
  <div class="max-w-[1440px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 border-t border-brand-grid">
      {teasers.map((t, i) => (
        <a
          href={t.link}
          class="group block border-b md:border-b-0 md:border-r border-brand-grid last:border-r-0 pt-8 md:pt-10 pb-10 md:pb-12"
        >
          <div class="px-0 md:px-8 lg:px-10">
            <span class="text-label text-brand-text-secondary tabular-nums">0{i + 1}</span>
            <div class="aspect-[3/2] mt-6 mb-8 overflow-hidden bg-brand-surface">
              <img
                src={t.image}
                alt={t.title}
                class="w-full h-full object-cover transition-transform duration-700 ease-formd group-hover:scale-[1.04]"
              />
            </div>
            <h3 class="text-label font-bold text-brand-primary mb-3">{t.title}</h3>
            <p class="text-body-sm text-brand-text-secondary leading-relaxed">{t.text}</p>
            <span class="inline-block text-label text-brand-accent mt-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              Read more
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
