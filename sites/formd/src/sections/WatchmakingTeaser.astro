---
const teasers = [
  {
    title: 'Watchmaking tradition',
    text: 'Rooted in classical horology, our methods honor the craft while embracing precision engineering.',
    image: 'https://source.unsplash.com/600x400/?watchmaker+hands+bench+detail',
    link: '/watchmaking/tradition',
  },
  {
    title: 'Research + Development',
    text: 'Our in-house R&D team pushes the boundaries of movement architecture and material science.',
    image: 'https://source.unsplash.com/600x400/?watch+movement+caliber+macro',
    link: '/watchmaking/rd',
  },
  {
    title: 'In-house calibers',
    text: 'Every caliber is designed, assembled, and regulated in our workshops. No third-party movements.',
    image: 'https://source.unsplash.com/600x400/?gears+machinery+precision',
    link: '/watchmaking/calibers',
  },
]
---

<section class="bg-white py-20 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {teasers.map((t) => (
        <a href={t.link} class="group block">
          <img src={t.image} alt={t.title} class="w-full h-52 object-cover" />
          <h3 class="text-sm font-bold text-[#0A0A0A] uppercase tracking-widest mt-6 mb-2">{t.title}</h3>
          <p class="text-sm text-[#666666] leading-relaxed">{t.text}</p>
          <span class="inline-block text-xs text-[#CC2200] mt-4 uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity">
            Read more
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
