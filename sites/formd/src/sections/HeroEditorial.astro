---
import { ThreeDRollingText, HorizontalTextReveal } from 'skiper-islands'
---

<section class="bg-white py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-center">
    <div>
      <ThreeDRollingText
        text="Bringing one idea further: Punkt 38 Update"
        as="h1"
        fontSize="clamp(2rem, 5vw, 3.5rem)"
        fontWeight={700}
        color="#0A0A0A"
        delay={0.1}
      />
      <div class="mt-6">
        <HorizontalTextReveal
          text="A mechanical movement redesigned from the ground up. Available now."
          as="p"
          fontSize="clamp(1rem, 1.5vw, 1.25rem)"
          fontWeight={400}
          color="#666666"
          delay={0.3}
        />
      </div>
      <a
        href="/watches/punkt-38"
        class="inline-block mt-8 px-8 py-3 bg-[#CC2200] text-white text-sm font-medium uppercase tracking-wider"
      >
        Discover now
      </a>
    </div>
    <div class="flex justify-center">
      <img
        src="https://picsum.photos/seed/watch+white+background+minimal/600/600"
        alt="Punkt 38"
        class="w-full max-w-md"
      />
    </div>
  </div>
</section>
