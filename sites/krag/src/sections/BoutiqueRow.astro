---
---

<section class="py-24 md:py-32 px-6 bg-brand-surface-dark">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-14">
      <div>
        <p class="section-label text-white/50 mb-3">Boutique Exclusives</p>
        <h2 class="heading-section text-white text-2xl md:text-3xl">Available only here.</h2>
      </div>
      <p class="text-sm text-white/50 max-w-sm">Not on the shelf anywhere. Small batch numbers. No reissues.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
      {[
        { name: 'Ridge 40 GMT MKII — Night Dial', batch: 'Batch 03/50', price: '$780' },
        { name: 'Cairn 38 Field — Bronze', batch: 'Batch 02/35', price: '$620' },
        { name: 'Traverse 39 — Frozen Blue', batch: 'Batch 01/40', price: '$890' },
      ].map((item) => (
        <div class="group relative bg-white/[0.03] border border-white/10 p-6 md:p-8 card-hover hover:bg-white/[0.06] hover:border-brand-warm/40">
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-warm to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />
          <p class="text-[10px] font-medium uppercase tracking-[0.16em] text-brand-warm mb-5">Limited Edition</p>
          <p class="text-lg font-bold uppercase tracking-[0.04em] text-white leading-tight">{item.name}</p>
          <p class="text-xs text-white/40 mt-2 uppercase tracking-[0.1em]">{item.batch}</p>
          <div class="mt-6 flex items-center justify-between">
            <p class="text-xl font-bold text-white tracking-tight">{item.price}</p>
            <a
              href="/collections/boutique"
              class="text-[10px] font-medium uppercase tracking-[0.14em] text-white/60 hover:text-white transition-colors"
            >
              Inquire →
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
