---
import { RollingText } from 'skiper-islands'

const quotes = [
  { quote: 'The Cairn 38 hits all the basics without trying too hard. A rare thing.', source: 'WornAndWound' },
  { quote: "Krag's Ridge 40 GMT offers dual-timezone utility at a price that doesn't punish.", source: 'Hodinkee' },
]
---

<section class="py-24 md:py-32 px-6 bg-white border-y border-brand-primary/10">
  <div class="max-w-5xl mx-auto text-center">
    <p class="section-label mb-10">As seen in</p>

    <div class="py-6 border-y border-brand-primary/10">
      <RollingText
        client:visible
        items={['Hodinkee', 'WornAndWound', 'Fratello', 'A Blog to Watch', 'Watchfinder']}
        speed={20}
        color="#0D0D0D"
        fontSize="clamp(14px, 2vw, 18px)"
      />
    </div>

    <div class="mt-16 grid md:grid-cols-2 gap-10 text-left">
      {quotes.map((item) => (
        <blockquote class="relative pl-6 border-l-2 border-brand-warm">
          <p class="text-brand-primary text-base md:text-lg leading-relaxed">“{item.quote}”</p>
          <cite class="block mt-4 text-[10px] font-bold uppercase tracking-[0.16em] text-brand-text-secondary not-italic">
            — {item.source}
          </cite>
        </blockquote>
      ))}
    </div>
  </div>
</section>
