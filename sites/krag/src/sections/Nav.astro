---
---

<div class="relative z-50">
  <nav class="flex items-center justify-between h-16 px-6 bg-white border-b border-gray-200 sticky top-0">
    <div class="flex items-center gap-8">
      <a href="/" class="text-xl font-bold tracking-[-0.05em] uppercase">KRAG</a>
      <div class="hidden md:flex items-center gap-6">
        {
          ['Watches', 'Collections', 'Reviews', 'About', 'Stores'].map((label) => (
            <a
              href={`/${label.toLowerCase()}`}
              class="text-sm font-medium text-[#111] hover:text-[#888] transition-colors relative inline-block overflow-hidden h-[1.2em] leading-[1.2em]"
            >
              <span class="group block">
                <span>{label}</span>
                <span class="absolute top-full left-0 text-[#888]">{label}</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
    <div class="flex items-center gap-4">
      <button class="text-sm text-brand-text-secondary">$</button>
      <button class="text-sm text-brand-text-secondary" aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6.5 6.5h11L19 18H5L6.5 6.5z"/><circle cx="9" cy="10" r="3"/><circle cx="15" cy="10" r="3"/></svg>
      </button>
      <button class="text-sm text-brand-text-secondary" aria-label="Account">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      </button>
    </div>
  </nav>
</div>
