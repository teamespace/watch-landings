---
---

<div class="relative z-50">
  <nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-brand-primary/5 h-16 px-6 flex items-center justify-between">
    <div class="flex items-center gap-8">
      <a href="/" class="text-xl font-bold tracking-[-0.06em] uppercase text-brand-primary hover:text-brand-accent transition-colors">
        KRAG
      </a>
      <div class="hidden md:flex items-center gap-7">
        {
          ['Watches', 'Collections', 'Reviews', 'About', 'Stores'].map((label) => (
            <a
              href={`/${label.toLowerCase()}`}
              class="group relative inline-block overflow-hidden h-[1.15em] leading-[1.15em] text-[11px] font-medium uppercase tracking-[0.14em] text-brand-primary"
            >
              <span class="block transition-transform duration-300 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:-translate-y-full">
                {label}
              </span>
              <span class="absolute top-full left-0 block text-brand-text-secondary transition-transform duration-300 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:-translate-y-full">
                {label}
              </span>
            </a>
          ))
        }
      </div>
    </div>
    <div class="flex items-center gap-5">
      <button class="text-[11px] font-medium uppercase tracking-[0.1em] text-brand-primary hover:text-brand-accent transition-colors">
        $
      </button>
      <button class="text-brand-primary hover:text-brand-accent transition-colors" aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6.5 6.5h11L19 18H5L6.5 6.5z"/>
          <circle cx="9" cy="10" r="3"/>
          <circle cx="15" cy="10" r="3"/>
        </svg>
      </button>
      <button class="text-brand-primary hover:text-brand-accent transition-colors" aria-label="Account">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
        </svg>
      </button>
    </div>
  </nav>
</div>
