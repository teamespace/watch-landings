---
import { ScrollImagesReveal } from 'skiper-islands'
import products from '../data/products.json'
---

<section class="py-24 md:py-32 px-6 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-14">
      <ScrollImagesReveal client:visible direction="up">
        <div>
          <p class="section-label mb-3">Our Collections</p>
          <h2 class="heading-section text-2xl md:text-3xl">Six watches. One terrain.</h2>
        </div>
      </ScrollImagesReveal>
      <a
        href="/collections"
        class="text-[11px] font-medium uppercase tracking-[0.14em] text-brand-text-secondary hover:text-brand-accent transition-colors"
      >
        View all watches →
      </a>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-5">
      {products.map((product) => {
        const seed = `watch+${encodeURIComponent(product.collection.split(' ').slice(-1)[0].toLowerCase())}`
        return (
          <a
            href={`/collections/${product.collection.toLowerCase().replace(/\s+/g, '-')}`}
            class="group block bg-brand-surface-mid card-hover hover:shadow-xl"
          >
            <div class="relative aspect-square overflow-hidden bg-[#E5E5E2]">
              <img
                src={`https://picsum.photos/seed/${seed}/700/700`}
                alt={product.collection}
                class="absolute inset-0 w-full h-full object-cover card-hover group-hover:scale-105"
              />
              <img
                src={`https://picsum.photos/seed/${seed}+alt/700/700`}
                alt={`${product.collection} alternate`}
                class="absolute inset-0 w-full h-full object-cover card-hover opacity-0 group-hover:opacity-100 group-hover:scale-105"
              />
            </div>
            <div class="p-4 md:p-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-xs md:text-sm font-bold uppercase tracking-[0.08em] text-brand-primary">
                    {product.collection}
                  </p>
                  <p class="text-[10px] md:text-xs uppercase tracking-[0.1em] text-brand-text-secondary mt-1">
                    {product.spec}
                  </p>
                </div>
                <p class="text-xs md:text-sm font-medium text-brand-primary">{product.price}</p>
              </div>
              <div class="mt-4 h-px bg-brand-primary/10 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />
              <p class="mt-3 text-[10px] md:text-xs font-medium uppercase tracking-[0.12em] text-brand-warm group-hover:text-brand-accent transition-colors">
                Discover <span aria-hidden="true">→</span>
              </p>
            </div>
          </a>
        )
      })}
    </div>
  </div>
</section>
