---
import { ScrollImagesReveal } from 'skiper-islands'
import products from '../data/products.json'
---

<section class="py-24 px-6 bg-white">
  <div class="max-w-7xl mx-auto">
    <ScrollImagesReveal client:visible direction="up">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-text-secondary mb-12">Our Collections</p>
    </ScrollImagesReveal>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map((product) => (
        <a
          href={`/collections/${product.collection.toLowerCase().replace(/\s+/g, '-')}`}
          class="group relative block overflow-hidden bg-[#EDEDEA]"
        >
          <div class="aspect-square overflow-hidden">
            <img
              src={`https://picsum.photos/seed/watch+/600/600${encodeURIComponent(product.collection.split(' ').slice(-1)[0].toLowerCase())}`}
              alt={product.collection}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="p-6">
            <p class="text-sm font-medium text-brand-primary">{product.collection}</p>
            <p class="text-xs text-brand-text-secondary mt-1 uppercase tracking-[0.15em]">Discover →</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
