---
---

<section class="py-24 px-6 bg-[#1A1A18]">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-white text-3xl md:text-4xl font-bold uppercase tracking-widest">
      Stay in the field
    </h2>
    <p class="text-white/60 text-sm mt-4 max-w-md mx-auto">
      New collection launches, limited drops, and shipping updates. That's it.
    </p>
    <form class="mt-8 flex gap-3 max-w-md mx-auto">
      <input
        type="email"
        placeholder="Your email"
        class="flex-1 px-4 py-3 bg-white/10 border border-white/20 text-white text-sm placeholder:text-white/40 focus:outline-none focus:border-white/60 transition-colors"
      />
      <button
        type="submit"
        class="px-6 py-3 bg-[#3B5E3A] text-white text-sm uppercase tracking-widest hover:bg-[#2d4a2d] transition-colors"
      >
        Subscribe
      </button>
    </form>
  </div>
</section>
