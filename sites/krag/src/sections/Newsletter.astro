<section class="py-24 md:py-32 px-6 bg-brand-surface-dark">
  <div class="max-w-2xl mx-auto text-center">
    <p class="section-label text-white/50 mb-3">Newsletter</p>
    <h2 class="heading-section text-white text-2xl md:text-4xl">Stay in the field</h2>
    <p class="text-white/60 text-sm mt-4 max-w-md mx-auto">
      New collection launches, limited drops, and shipping updates. That's it.
    </p>

    <form class="mt-10 flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input
        type="email"
        placeholder="Your email"
        class="flex-1 px-4 py-3 bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/30 focus:outline-none focus:border-brand-warm/60 transition-colors uppercase tracking-wider"
      />
      <button type="submit" class="btn-primary">
        Subscribe
      </button>
    </form>
  </div>
</section>
