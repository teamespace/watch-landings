<section class="relative py-32 md:py-48 bg-brand-surface-dark overflow-hidden">
  <img
    src="https://picsum.photos/seed/store+interior+minimal/1920/900"
    alt="Showroom interior"
    class="absolute inset-0 w-full h-full object-cover opacity-60"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-brand-surface-dark via-brand-surface-dark/60 to-transparent" />

  <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
    <p class="section-label text-white/50 mb-4">Showroom</p>
    <h2 class="heading-section text-white text-3xl md:text-5xl max-w-3xl mx-auto">
