---
---

<section class="relative py-24 bg-[#1A1A18]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="relative h-[400px] overflow-hidden mb-12">
      <img
        src="https://picsum.photos/seed/store+interior+minimal/1920/600"
        alt="Showroom interior"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/30" />
    </div>
    <div class="text-center">
      <h2 class="text-white text-3xl md:text-4xl font-bold uppercase tracking-wide">
        We have a place you can visit.
      </h2>
      <p class="text-white/60 text-base mt-4 max-w-lg mx-auto">
        Our showroom in Portland is open Tuesday to Saturday. Come see the watches before you buy.
      </p>
      <a
        href="/stores"
        class="inline-block mt-8 px-8 py-3 border border-white text-white text-sm uppercase tracking-widest hover:bg-white hover:text-black transition-colors"
      >
        Find us
      </a>
    </div>
  </div>
</section>
