---
import products from '../data/products.json'
const newProducts = products.filter(p => p.new)
---

<section class="py-16 md:py-20 px-6 max-w-6xl mx-auto">
  <div class="flex items-end justify-between mb-10 md:mb-12">
    <h2 class="text-[11px] uppercase tracking-label text-brand-text-secondary">New arrivals</h2>
    <span class="hidden sm:block text-[11px] uppercase tracking-label text-brand-text-muted">{newProducts.length} watches</span>
  </div>
  <div class="grid grid-cols-2 md:grid-cols-3 gap-5 md:gap-7">
    {newProducts.map((p, i) => (
      <a href={`/products/${p.id}`} class="group block animate-fade-in" style={`animation-delay: ${i * 0.1}s`}>
        <div class="aspect-square bg-brand-surface mb-4 overflow-hidden relative">
          <img
            src={`https://picsum.photos/seed/watch+warm+cream+background+${encodeURIComponent(p.name)}/500/500`}
            alt={p.name}
            class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-700 ease-out"
            loading="lazy"
          />
          <span class="absolute top-3 left-3 bg-brand-accent text-white text-[10px] uppercase tracking-wider px-2.5 py-1">New</span>
        </div>
        <div class="space-y-0.5">
          <h3 class="font-display text-base md:text-lg text-brand-primary uppercase tracking-wide">{p.name}</h3>
          <p class="text-[13px] text-brand-text-secondary lowercase">{p.collection}</p>
          <p class="text-sm text-brand-primary font-medium pt-1">{p.price}</p>
        </div>
      </a>
    ))}
  </div>
  <div class="mt-14 text-center">
    <a href="/shop" class="inline-block border border-brand-primary text-brand-primary px-10 py-3 text-sm font-medium tracking-wide hover:bg-brand-primary hover:text-brand-background transition-colors duration-300">
      Shop all watches
    </a>
  </div>
</section>
