---
import products from '../data/products.json'
const newProducts = products.filter(p => p.new)
---

<section class="py-16 px-6 max-w-6xl mx-auto">
  <h2 class="text-[11px] uppercase tracking-[0.2em] text-[#7A7A72] mb-10">New arrivals</h2>
  <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
    {newProducts.map((p, i) => (
      <div class="group cursor-pointer animate-fade-in" style={`animation-delay: ${i * 0.1}s`}>
        <div class="aspect-square bg-[#EFEDE8] mb-3 overflow-hidden relative">
          <img
            src={`https://source.unsplash.com/400x400/?watch+warm+cream+background+${encodeURIComponent(p.name)}`}
            alt={p.name}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
          <span class="absolute top-2 left-2 bg-[#C4573A] text-white text-[10px] uppercase tracking-wider px-2 py-0.5">New</span>
        </div>
        <h3 class="font-display text-base text-[#1C1C1A]">{p.name}</h3>
        <p class="text-[#7A7A72] text-sm">{p.price}</p>
      </div>
    ))}
  </div>
  <div class="mt-12 text-center">
    <a href="/shop" class="inline-block border border-[#1C1C1A] text-[#1C1C1A] px-10 py-3 text-sm font-medium tracking-wide hover:bg-[#1C1C1A] hover:text-white transition-colors">
      Shop all watches
    </a>
  </div>
</section>
