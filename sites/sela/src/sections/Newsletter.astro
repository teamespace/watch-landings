---
---

<section class="py-20 px-6 bg-[#EFEDE8]">
  <div class="max-w-lg mx-auto text-center">
    <h2 class="font-display text-3xl md:text-4xl text-[#1C1C1A] mb-4">Stay close.</h2>
    <p class="text-[15px] text-[#7A7A72] mb-8 leading-relaxed">
      New releases, upcoming events, and occasional stories from the studio.
    </p>
    <form class="flex flex-col sm:flex-row gap-3" onsubmit="alert('Thanks for subscribing!');return false">
      <input
        type="email"
        placeholder="Your email"
        required
        class="flex-1 border border-gray-200 bg-white px-4 py-3 text-sm outline-none focus:border-[#C4573A] transition-colors"
      />
      <button
        type="submit"
        class="bg-[#C4573A] text-white px-8 py-3 text-sm font-medium tracking-wide hover:bg-[#A03E2E] transition-colors whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>
    <p class="text-[11px] text-[#7A7A72] mt-4">No spam. Unsubscribe anytime.</p>
  </div>
</section>
