---
---

<section class="py-20 md:py-24 px-6 bg-brand-surface">
  <div class="max-w-lg mx-auto text-center">
    <h2 class="font-display text-3xl md:text-4xl text-brand-primary mb-4">Stay close.</h2>
    <p class="text-[15px] leading-[1.7] text-brand-text-secondary mb-8">
      New releases, upcoming events, and occasional stories from the studio.
    </p>
    <form class="flex flex-col sm:flex-row gap-3" onsubmit="alert('Thanks for subscribing!');return false">
      <input
        type="email"
        placeholder="Your email"
        required
        class="flex-1 border border-brand-surface-warm bg-brand-background px-4 py-3 text-sm outline-none focus:border-brand-accent transition-colors duration-300 placeholder:text-brand-text-muted"
      />
      <button
        type="submit"
        class="bg-brand-accent text-white px-8 py-3 text-sm font-medium tracking-wide hover:bg-brand-accent-hover transition-colors duration-300 whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>
    <p class="text-[11px] text-brand-text-muted mt-4">No spam. Unsubscribe anytime.</p>
  </div>
</section>
