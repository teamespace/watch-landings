---
const accessories = [
  { id: 'strap-1', name: 'Woven NATO Strap', price: '$45', img: 'https://picsum.photos/seed/watch+strap+leather+detail/400/400' },
  { id: 'strap-2', name: 'Terracotta Leather Strap', price: '$65', img: 'https://picsum.photos/seed/leather+watch+strap+brown/400/400' },
  { id: 'bezel-1', name: 'Steel GMT Bezel', price: '$85', img: 'https://picsum.photos/seed/watch+bezel+steel/400/400' },
  { id: 'pouch', name: 'Travel Pouch', price: '$35', img: 'https://picsum.photos/seed/fabric+pouch+travel/400/400' },
  { id: 'spring', name: 'Spring Bar Tool', price: '$12', img: 'https://picsum.photos/seed/tool+metal+detail/400/400' },
]
---

<section class="py-16 md:py-20 px-6 max-w-6xl mx-auto">
  <h2 class="text-[11px] uppercase tracking-label text-brand-text-secondary mb-10">The details</h2>
  <div class="flex gap-5 md:gap-6 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide -mx-6 px-6">
    {accessories.map((item) => (
      <a href={`/accessories/${item.id}`} class="snap-start shrink-0 group">
        <div class="w-[170px] md:w-[200px]">
          <div class="aspect-square bg-brand-surface overflow-hidden mb-3">
            <img src={item.img} alt={item.name} class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-700 ease-out" loading="lazy" />
          </div>
          <h3 class="font-display text-sm md:text-base text-brand-primary">{item.name}</h3>
          <p class="text-sm text-brand-text-secondary mt-0.5">{item.price}</p>
        </div>
      </a>
    ))}
  </div>
</section>
