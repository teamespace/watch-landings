<section class="py-18 md:py-24 px-6 max-w-4xl mx-auto text-center">
  <p class="text-[11px] uppercase tracking-label text-brand-text-secondary mb-10">How we work</p>
  <div class="flex items-start justify-center gap-4 md:gap-10 mb-10">
    <div class="flex flex-col items-center max-w-[120px]">
      <div class="w-14 h-14 rounded-full bg-brand-surface flex items-center justify-center mb-3">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C4573A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
      </div>
      <span class="text-[11px] uppercase tracking-wide text-brand-text-secondary">Sketch</span>
    </div>
    <div class="pt-6">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9C5BC" stroke-width="1" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </div>
    <div class="flex flex-col items-center max-w-[120px]">
      <div class="w-14 h-14 rounded-full bg-brand-surface flex items-center justify-center mb-3">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C4573A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/>
        </svg>
      </div>
      <span class="text-[11px] uppercase tracking-wide text-brand-text-secondary">Prototype</span>
    </div>
    <div class="pt-6">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9C5BC" stroke-width="1" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </div>
    <div class="flex flex-col items-center max-w-[120px]">
      <div class="w-14 h-14 rounded-full bg-brand-surface flex items-center justify-center mb-3">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C4573A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
        </svg>
      </div>
      <span class="text-[11px] uppercase tracking-wide text-brand-text-secondary">Production</span>
    </div>
  </div>
  <p class="text-[15px] md:text-base leading-[1.7] text-brand-primary mb-8 max-w-md mx-auto">
    From first sketch to finished watch, we show our work.
  </p>
  <a href="/design-process" class="inline-block border border-brand-primary text-brand-primary px-8 py-3 text-sm font-medium tracking-wide hover:bg-brand-primary hover:text-brand-background transition-colors duration-300">
    Our design process
  </a>
</section>
