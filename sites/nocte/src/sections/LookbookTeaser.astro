---
import { ScrollImagesReveal } from 'skiper-islands/reveal/ScrollImagesReveal'
import { ScrollWithFade } from 'skiper-islands/scroll/ScrollWithFade'

const stories = [
  { id: 'tokyo', title: 'Tokyo, January', img: 'https://picsum.photos/seed/tokyo+night+editorial+photo/800/600' },
  { id: 'oslo', title: 'Oslo, March', img: 'https://picsum.photos/seed/oslo+architecture+minimal/800/600' },
  { id: 'capetown', title: 'Cape Town, August', img: 'https://picsum.photos/seed/cape+town+editorial+landscape/800/600' },
]
---

<section id="lookbook" class="py-28 md:py-36 px-6 bg-[#F7F5F2]">
  <div class="max-w-7xl mx-auto">
    <ScrollWithFade>
      <h2 class="section-title mb-4">Lookbook</h2>
      <p class="section-subtitle mb-16 md:mb-24">Where Nocte lives.</p>
    </ScrollWithFade>

    <div class="grid grid-cols-1 md:grid-cols-12 md:grid-rows-2 gap-4 md:gap-6">
      <!-- Large left -->
      <a href="#" class="group md:col-span-7 md:row-span-2 flex flex-col">
        <ScrollImagesReveal direction="left" className="flex-1 min-h-[420px] md:min-h-0">
          <div class="relative overflow-hidden h-full">
            <img
              src={stories[0].img}
              alt={stories[0].title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-500" />
          </div>
        </ScrollImagesReveal>
        <div class="mt-5">
          <h3 class="font-display text-2xl md:text-3xl text-[#1A1A1A]">{stories[0].title}</h3>
          <p class="section-subtitle mt-1">View story →</p>
        </div>
      </a>

      <!-- Right top -->
      <a href="#" class="group md:col-span-5 flex flex-col">
        <ScrollImagesReveal direction="up" className="flex-1 min-h-[280px] md:min-h-0">
          <div class="relative overflow-hidden h-full">
            <img
              src={stories[1].img}
              alt={stories[1].title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-500" />
          </div>
        </ScrollImagesReveal>
        <div class="mt-5">
          <h3 class="font-display text-2xl text-[#1A1A1A]">{stories[1].title}</h3>
          <p class="section-subtitle mt-1">View story →</p>
        </div>
      </a>

      <!-- Right bottom -->
      <a href="#" class="group md:col-span-5 flex flex-col">
        <ScrollImagesReveal direction="right" className="flex-1 min-h-[280px] md:min-h-0">
          <div class="relative overflow-hidden h-full">
            <img
              src={stories[2].img}
              alt={stories[2].title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-500" />
          </div>
        </ScrollImagesReveal>
        <div class="mt-5">
          <h3 class="font-display text-2xl text-[#1A1A1A]">{stories[2].title}</h3>
          <p class="section-subtitle mt-1">View story →</p>
        </div>
      </a>
    </div>
  </div>
</section>
