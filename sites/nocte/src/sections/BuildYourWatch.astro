---
import { BuildWatch } from '../components/BuildWatch'
import { ScrollWithFade } from 'skiper-islands/scroll/ScrollWithFade'
---

<section class="py-28 md:py-36 px-6 bg-[#F7F5F2]">
  <div class="max-w-5xl mx-auto">
    <ScrollWithFade>
      <h2 class="section-title text-center mb-5">Make it yours.</h2>
      <p class="text-body text-center max-w-lg mx-auto mb-16 md:mb-20">
        Choose your case, pick a strap, see the result before you buy.
      </p>
    </ScrollWithFade>

    <div class="build-watch overflow-x-auto -mx-6 px-6 md:mx-0 md:px-0">
      <BuildWatch client:load />
    </div>

    <div class="text-center mt-14">
      <a href="#" class="btn-dark">Start building</a>
    </div>
  </div>
</section>
