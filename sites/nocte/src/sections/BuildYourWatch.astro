---
import { BuildWatch } from '../components/BuildWatch'
import { ScrollWithFade } from 'skiper-islands/scroll/ScrollWithFade'
---

<section class="py-24 px-6 bg-[#F7F5F2]">
  <div class="max-w-5xl mx-auto">
    <ScrollWithFade>
      <h2 class="font-display text-4xl md:text-5xl text-[#1A1A1A] mb-4 text-center">Make it yours.</h2>
    </ScrollWithFade>

    <p class="text-center text-[#6B6B6B] text-sm mb-12 max-w-md mx-auto">
      Choose your case, pick a strap, see the result before you buy.
    </p>

    <BuildWatch client:load />

    <div class="text-center mt-10">
      <a href="#" class="inline-block bg-[#1A1A1A] text-white px-10 py-3 text-sm tracking-[0.2em] uppercase hover:bg-[#333] transition-colors">
        Start building
      </a>
    </div>
  </div>
</section>
