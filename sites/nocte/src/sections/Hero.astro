---
import { MouseFollowAnimations } from 'skiper-islands/effects/MouseFollowAnimations'
import { ParallaxImage } from 'skiper-islands/effects/ParallaxImage'
---

<section class="min-h-screen bg-[#111111] relative overflow-hidden flex items-center">
  <div class="absolute inset-0 bg-gradient-to-br from-[#1a1a1a] via-[#111111] to-[#0a0a0a]"></div>
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22 opacity=%221%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size: 200px;"
  ></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,#111111_80%)] opacity-60"></div>

  <div class="relative z-10 flex flex-col md:flex-row w-full min-h-screen">
    <div class="w-full md:w-[60%] h-[55vh] md:h-auto md:min-h-screen overflow-hidden">
      <MouseFollowAnimations maxShift={10} className="h-full">
        <ParallaxImage depth={0.12} className="h-full">
          <img
            src="https://picsum.photos/seed/watch+wrist+dark+moody/800/1000"
            alt="Nocte watch on wrist"
            class="w-full h-full object-cover object-center scale-105"
          />
        </ParallaxImage>
      </MouseFollowAnimations>
    </div>

    <div class="w-full md:w-[40%] flex flex-col justify-center px-8 md:px-16 lg:px-24 py-20 md:py-0 pt-24 md:pt-0">
      <h1
        class="font-display text-white text-[clamp(2.75rem,5.5vw,5rem)] leading-[1.05] font-semibold animate-fade-in-up"
        style="font-family: 'Cormorant Garamond', Georgia, serif;"
      >
        Something you'll wear for the next ten years.
      </h1>

      <p class="mt-8 max-w-md text-[15px] leading-[1.7] text-[#a0a0a0] animate-fade-in-up" style="animation-delay: 0.2s;">
        Nocte watches are designed with one question in mind: does it still make sense in a decade?
      </p>

      <div class="mt-12 animate-fade-in-up" style="animation-delay: 0.4s;">
        <a href="#collections" class="btn-primary">Shop the collection</a>
      </div>
    </div>
  </div>
</section>
