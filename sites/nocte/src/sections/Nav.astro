---
import { TextRollNavigation } from 'skiper-islands/nav/TextRollNavigation'
import { ScrollWithFade } from 'skiper-islands/scroll/ScrollWithFade'
import { MobileNav } from '../components/MobileNav'
---

<ScrollWithFade>
  <nav
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent text-white"
    id="nocte-nav"
  >
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
      <a href="/" class="font-display text-2xl md:text-3xl tracking-wider text-current" id="nav-logo">nocte</a>

      <div class="nav-links hidden md:flex items-center gap-10">
        <TextRollNavigation
          links={[
            { label: 'Collections', href: '#collections' },
            { label: 'Lookbook', href: '#lookbook' },
            { label: 'About', href: '#about' },
          ]}
          textColor="#ffffff"
          hoverColor="#C9A96E"
          fontSize="12px"
        />
      </div>

      <div class="flex items-center gap-6">
        <button class="text-current label-upper hidden md:block" id="search-btn">Search</button>
        <button class="text-current label-upper relative" id="cart-btn">
          Cart <span class="absolute -top-2 -right-5 bg-brand-accent text-[10px] w-4 h-4 rounded-full flex items-center justify-center text-white">0</span>
        </button>
        <div class="md:hidden">
          <MobileNav client:load />
        </div>
      </div>
    </div>
  </nav>
</ScrollWithFade>

<script>
  const nav = /** @type {HTMLElement} */ (document.getElementById('nocte-nav'))

  const observer = new IntersectionObserver(
    ([entry]) => {
      if (!nav) return
      const atTop = entry.isIntersecting
      nav.classList.toggle('bg-transparent', atTop)
      nav.classList.toggle('text-white', atTop)
      nav.classList.toggle('bg-[#111]/95', !atTop)
      nav.classList.toggle('md:bg-white', !atTop)
      nav.classList.toggle('md:text-[#1A1A1A]', !atTop)
      nav.classList.toggle('shadow-sm', !atTop)
    },
    { threshold: 0 }
  )

  const hero = document.querySelector('main > section:first-child')
  if (hero && nav) observer.observe(hero)
</script>
