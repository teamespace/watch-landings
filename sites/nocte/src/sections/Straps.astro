---
import { ScrollImagesReveal } from 'skiper-islands/reveal/ScrollImagesReveal'
import { ScrollWithFade } from 'skiper-islands/scroll/ScrollWithFade'

const straps = [
  { id: 'strap-calf', name: 'Calf Leather Strap', price: '$80', img: 'https://picsum.photos/seed/watch+strap+leather+brown/300/300' },
  { id: 'strap-suede', name: 'Suede Strap', price: '$65', img: 'https://picsum.photos/seed/watch+strap+suede/300/300' },
  { id: 'strap-canvas', name: 'Canvas Strap', price: '$45', img: 'https://picsum.photos/seed/watch+strap+canvas/300/300' },
  { id: 'strap-steel', name: 'Steel Bracelet', price: '$150', img: 'https://picsum.photos/seed/watch+bracelet+steel/300/300' },
]
---

<section class="py-28 md:py-36 px-6 bg-[#F7F5F2]">
  <div class="max-w-7xl mx-auto">
    <ScrollWithFade>
      <h2 class="section-title mb-4">Change it up.</h2>
      <p class="section-subtitle mb-16 md:mb-24">Every watch deserves a second look.</p>
    </ScrollWithFade>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
      {straps.map((s) => (
        <a href="#" class="group block">
          <ScrollImagesReveal direction="up" className="mb-5">
            <div class="bg-[#E8E6E3] aspect-[4/5] overflow-hidden">
              <img src={s.img} alt={s.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
          </ScrollImagesReveal>
          <h3 class="font-body text-sm font-bold text-[#1A1A1A] tracking-[0.15em] uppercase">{s.name}</h3>
          <p class="text-xs text-[#6B6B6B] mt-1">{s.price}</p>
        </a>
      ))}
    </div>

    <div class="text-center mt-16">
      <ScrollWithFade>
        <a href="#" class="btn-dark">Shop straps</a>
      </ScrollWithFade>
    </div>
  </div>
</section>
